   "source": [
    "#converting tempurature between celsius and farhenite\n",
    "def convert_temp(temp,unit):\n",
    "    if unit=='C':\n",
    "        return temp *9/5 +32\n",
    "    elif unit=='f':\n",
    "        return (temp-32)*5/9\n",
    "    else:\n",
    "        print(\"not entered\")\n",
    "print(convert_temp(25,'C'))\n",
    "print(convert_temp(25,'f'))"
   ]
  }
