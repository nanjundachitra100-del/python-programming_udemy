    "#check if the given string is palindrome or no\n",
    "def palindrome(s):\n",
    "    s=s.lower().replace(\" \",\"\")\n",
    "    return s == s[::-1]\n",
    "print(palindrome('madam'))\n",
    "print(palindrome('apple'))\n"
   ]
  }
